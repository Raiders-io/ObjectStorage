# Node
TZ=UTC
API_PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${API_PORT}

# Object Storage
OBJECT_STORAGE_PORT=3900
GARAGE_DEFAULT_SECRET_KEY=
GARAGE_DEFAULT_ACCESS_KEY=
GARAGE_DEFAULT_BUCKET=default-bucket
# syntax is 'garage=${LOG}', with LOG=error, warn, info (default), debug and trace.
GARAGE_RUST_LOG=info
GARAGE_SERVICE_NAME=garage

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=garage
POSTGRES_SERVICE_NAME=postgresql
POSTGRES_HOST=${POSTGRES_SERVICE_NAME}
POSTGRES_PORT=5432

# API
DRIVE_DISK=s3
AWS_ACCESS_KEY_ID=${GARAGE_DEFAULT_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${GARAGE_DEFAULT_SECRET_KEY}
AWS_REGION=garage # This should match the s3_region in garage.toml
S3_BUCKET=${GARAGE_DEFAULT_BUCKET}
S3_ENDPOINT=http://${GARAGE_SERVICE_NAME}:${OBJECT_STORAGE_PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
